<Window x:Class="StarArk.LightingTuner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StarArk.LightingTuner"
        mc:Ignorable="d"
        Title="StarArk Lighting Tuner" Height="760" Width="640"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="6"/>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TickPlacement" Value="None"/>
            <Setter Property="IsSnapToTickEnabled" Value="False"/>
        </Style>
    </Window.Resources>
    <DockPanel>
        <Border DockPanel.Dock="Top" Padding="8" Background="#222">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <CheckBox x:Name="AutoApplyCheck" Content="自动保存"
                              Foreground="White" VerticalAlignment="Center"
                              IsChecked="True" Margin="0,0,12,0"/>
                    <Button Content="重新加载" Click="OnReload" Padding="10,4" Margin="2,0"/>
                    <Button Content="保存"     Click="OnApply"  Padding="10,4" Margin="2,0"/>
                    <Button Content="浏览…"    Click="OnBrowse" Padding="10,4" Margin="2,0"/>
                </StackPanel>
                <TextBlock x:Name="PathText" Foreground="#CCC"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Ready"/>
            </StatusBarItem>
        </StatusBar>
        <TabControl x:Name="Tabs" Margin="4"/>
    </DockPanel>
</Window>