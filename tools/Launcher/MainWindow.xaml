<Window x:Class="StarArk.Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding GameTitle, FallbackValue=StarArk Launcher}"
        Width="900" Height="600"
        WindowStartupLocation="CenterScreen"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- header -->
            <RowDefinition Height="Auto"/>   <!-- pipeline bar -->
            <RowDefinition Height="*"/>      <!-- main two columns -->
            <RowDefinition Height="Auto"/>   <!-- validation -->
            <RowDefinition Height="Auto"/>   <!-- footer -->
        </Grid.RowDefinitions>

        <!-- ===== Header ===== -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="{Binding GameTitle}" FontSize="22" FontWeight="SemiBold"/>
            <TextBlock Foreground="{StaticResource FgDim}" FontSize="11" Margin="0,2,0,0">
                <Run Text="Runtime:"/>
                <Run Text="{Binding RuntimeExeName, Mode=OneWay}"/>
                <Run Text="    Dir:"/>
                <Run Text="{Binding BaseDirDisplay, Mode=OneWay}"/>
            </TextBlock>
        </StackPanel>

        <!-- ===== Pipeline ===== -->
        <Border Grid.Row="1" Style="{StaticResource Panel}" Padding="10,8" Margin="0,0,0,12">
            <StackPanel x:Name="PipelinePanel" Orientation="Horizontal">
                <TextBlock Text="渲染管线:" Foreground="{StaticResource FgDim}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <!-- RadioButtons populated in code-behind -->
            </StackPanel>
        </Border>

        <!-- ===== Two columns ===== -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- Games -->
            <Border Grid.Column="0" Style="{StaticResource Panel}">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="{StaticResource Bg2}" Padding="10,6">
                        <TextBlock Text="游戏 (Games)" FontWeight="SemiBold"/>
                    </Border>
                    <ListBox ItemsSource="{Binding Games}"
                             SelectedItem="{Binding SelectedGame, Mode=TwoWay}"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Subtitle}"
                                               Foreground="{StaticResource FgDim}" FontSize="11"/>
                                    <TextBlock Text="{Binding IssueText}" Foreground="{StaticResource Error}"
                                               FontSize="11" TextWrapping="Wrap"
                                               Visibility="{Binding HasIssue, Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Addons -->
            <Border Grid.Column="2" Style="{StaticResource Panel}">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="{StaticResource Bg2}" Padding="10,6">
                        <TextBlock Text="附加 (Addons)" FontWeight="SemiBold"/>
                    </Border>
                    <ListBox ItemsSource="{Binding Addons}" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                          IsEnabled="{Binding IsEnabled}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Subtitle}"
                                                   Foreground="{StaticResource FgDim}" FontSize="11"/>
                                    </StackPanel>
                                </CheckBox>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Detail -->
            <Border Grid.Column="4" Style="{StaticResource Panel}">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="{StaticResource Bg2}" Padding="10,6">
                        <TextBlock Text="详情" FontWeight="SemiBold"/>
                    </Border>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBlock Text="{Binding SelectedDescription}"
                                   Padding="14,10" TextWrapping="Wrap" FontFamily="Consolas, Microsoft YaHei UI"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ===== Validation ===== -->
        <Border Grid.Row="3" Style="{StaticResource Panel}" Margin="0,12,0,0" Padding="10,8">
            <TextBlock Text="{Binding ValidationSummary}" Foreground="{StaticResource Warn}" TextWrapping="Wrap"/>
        </Border>

        <!-- ===== Footer ===== -->
        <Grid Grid.Row="4" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="刷新" Click="Refresh_Click" Margin="0,0,8,0"/>
                <Button Content="打开 mods 文件夹" Click="OpenModsFolder_Click"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="退出" Click="Quit_Click" Margin="0,0,8,0"/>
                <Button Content="▶ 启动" Style="{StaticResource AccentButton}"
                        IsEnabled="{Binding CanLaunch}"
                        Click="Launch_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
