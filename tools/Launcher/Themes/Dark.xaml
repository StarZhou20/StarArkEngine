<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <BooleanToVisibilityConverter x:Key="BoolToVis"/>

    <!-- ========= Palette ========= -->
    <Color x:Key="Bg0Color">#FF14171C</Color>   <!-- window bg -->
    <Color x:Key="Bg1Color">#FF1C2027</Color>   <!-- panel -->
    <Color x:Key="Bg2Color">#FF252A33</Color>   <!-- panel hover -->
    <Color x:Key="Bg3Color">#FF323845</Color>   <!-- selected -->
    <Color x:Key="BorderColor">#FF3A4150</Color>
    <Color x:Key="FgColor">#FFE4E7EE</Color>
    <Color x:Key="FgDimColor">#FF8B93A4</Color>
    <Color x:Key="AccentColor">#FF5BA3FF</Color>
    <Color x:Key="AccentHoverColor">#FF7AB6FF</Color>
    <Color x:Key="WarnColor">#FFE6B85A</Color>
    <Color x:Key="ErrorColor">#FFE26666</Color>

    <SolidColorBrush x:Key="Bg0" Color="{StaticResource Bg0Color}"/>
    <SolidColorBrush x:Key="Bg1" Color="{StaticResource Bg1Color}"/>
    <SolidColorBrush x:Key="Bg2" Color="{StaticResource Bg2Color}"/>
    <SolidColorBrush x:Key="Bg3" Color="{StaticResource Bg3Color}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="Fg" Color="{StaticResource FgColor}"/>
    <SolidColorBrush x:Key="FgDim" Color="{StaticResource FgDimColor}"/>
    <SolidColorBrush x:Key="Accent" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHover" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="Warn" Color="{StaticResource WarnColor}"/>
    <SolidColorBrush x:Key="Error" Color="{StaticResource ErrorColor}"/>

    <!-- ========= Defaults ========= -->
    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource Bg0}"/>
        <Setter Property="Foreground" Value="{StaticResource Fg}"/>
        <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Fg}"/>
    </Style>

    <Style TargetType="Border" x:Key="Panel">
        <Setter Property="Background" Value="{StaticResource Bg1}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
    </Style>

    <!-- ========= Button ========= -->
    <Style TargetType="Button">
        <Setter Property="Background" Value="{StaticResource Bg2}"/>
        <Setter Property="Foreground" Value="{StaticResource Fg}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="14,6"/>
        <Setter Property="MinWidth" Value="80"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{StaticResource Bg3}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Button" x:Key="AccentButton" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{StaticResource Accent}"/>
        <Setter Property="Foreground" Value="#FF0E1218"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
        <Setter Property="MinWidth" Value="120"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{StaticResource AccentHover}"/>
                            <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource AccentHover}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ========= ListBox ========= -->
    <Style TargetType="ListBox">
        <Setter Property="Background" Value="{StaticResource Bg1}"/>
        <Setter Property="Foreground" Value="{StaticResource Fg}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
    </Style>

    <Style TargetType="ListBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource Fg}"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="Margin" Value="2,1"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="b" Background="{TemplateBinding Background}"
                            CornerRadius="3" Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{StaticResource Bg2}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{StaticResource Bg3}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ========= CheckBox ========= -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource Fg}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <!-- ========= RadioButton ========= -->
    <Style TargetType="RadioButton">
        <Setter Property="Foreground" Value="{StaticResource Fg}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,12,0"/>
    </Style>

    <!-- ========= ScrollBar (slim dark) ========= -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width" Value="10"/>
    </Style>
</ResourceDictionary>
